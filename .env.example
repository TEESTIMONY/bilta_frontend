## Optional CMS endpoint for products
## If provided, the app will fetch products from this URL.
## If omitted or request fails, the app falls back to local products data.
VITE_CMS_PRODUCTS_URL=
VITE_USE_DJANGO_API=false
VITE_DJANGO_API_BASE=http://127.0.0.1:8000/api

## Team editor route toggle (set true only in private/internal environments)
VITE_ENABLE_TEAM_EDITOR=false
VITE_TEAM_ACCESS_CODE=

## Optional Sanity settings (used before generic CMS URL)
## If set, products are fetched from Sanity dataset query.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=
VITE_SANITY_API_VERSION=2024-01-01

## Django REST backend settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=

## Database (SQLite default)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

## Production security toggles
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
CSRF_TRUSTED_ORIGINS=

## CORS
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
